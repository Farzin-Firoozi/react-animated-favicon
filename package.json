{
  "name": "react-animated-favicon",
  "version": "1.0.1",
  "packageManager": "pnpm@10.33.2",
  "description": "Zero-dependency React library for animated GIF favicons, entirely client-side",
  "main": "./dist/react-animated-favicon.cjs.js",
  "module": "./dist/react-animated-favicon.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-animated-favicon.es.js",
      "require": "./dist/react-animated-favicon.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "vite build --watch",
    "dev:example": "pnpm --filter react-animated-favicon-demo dev",
    "build:example": "pnpm --filter react-animated-favicon-demo build",
    "deploy:example": "pnpm --filter react-animated-favicon-demo run deploy",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "favicon",
    "gif",
    "animated",
    "react",
    "hook",
    "browser",
    "typescript"
  ],
  "author": "Farzin Firoozi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/farzin-firoozi/react-animated-favicon"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "dependencies": {
    "gifuct-js": "^2.1.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
